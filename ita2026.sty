% ita2026.sty - approximate latex version of ita_papertemplate2026.docx
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ita2026}[2026/03/03 ITA 2026 layout]

\RequirePackage[b5paper,inner=2.0cm,outer=1.5cm,top=1.5cm,bottom=1.5cm]{geometry}

\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{newtxtext}
\RequirePackage{newtxmath}
\RequirePackage{microtype}

\setlength{\parindent}{1cm}
\setlength{\parskip}{0pt}
\linespread{1.0}

\RequirePackage{titlesec}
\titleformat{\section}
  {\normalfont\bfseries\fontsize{12}{14}\selectfont}
  {}
  {0pt}
  {}
\titleformat{\subsection}
  {\normalfont\bfseries\fontsize{11}{13}\selectfont}
  {}
  {0pt}
  {}
\titlespacing*{\section}{0pt}{10pt}{6pt}
\titlespacing*{\subsection}{0pt}{8pt}{4pt}

\newcommand{\ITAshorttitle}{}
\newcommand{\ITAshortauthor}{}

\newcommand{\ITArule}{
  \vspace{4pt}
  \hrule height 0.4pt
  \vspace{6pt}
}

\newcommand{\ITApagefooter}{
  \parbox[b]{2.2cm}{
    \raggedleft
    \rule{1.6cm}{0.4pt}\par
    \vspace{2pt}
    \fontsize{10}{12}\selectfont \thepage
  }
}

\RequirePackage{fancyhdr}
\fancyhf{}

\fancypagestyle{itaMain}{
  \fancyhf{}
  \fancyhead[L]{\fontsize{10}{12}\selectfont\ITAshortauthor}
  \fancyhead[R]{\fontsize{10}{12}\selectfont\ITAshorttitle}
  \renewcommand{\headrulewidth}{0.4pt}
  \renewcommand{\footrulewidth}{0pt}
  \fancyfoot[R]{\ITApagefooter}
}

\fancypagestyle{itaFirst}{
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
  \fancyfoot[R]{\ITApagefooter}
}

\pagestyle{itaMain}

\newcommand{\ITAjournalhead}[2]{
  \thispagestyle{itaFirst}
  \noindent
  \begin{minipage}[t]{0.62\linewidth}
    \fontsize{10}{12}\selectfont #1
  \end{minipage}
  \hfill
  \begin{minipage}[t]{0.35\linewidth}
    \raggedleft\fontsize{10}{12}\selectfont #2
  \end{minipage}
  \par
  \vspace{1.5\baselineskip}
}

\newcommand{\ITAtitle}[1]{
  \begin{center}
    \bfseries\fontsize{14}{16}\selectfont
    \MakeUppercase{#1}\par
  \end{center}
  \vspace{\baselineskip}
}

\newcommand{\ITAauthors}[1]{
  \begin{center}
    \bfseries\fontsize{11}{13}\selectfont
    #1\par
  \end{center}
  \vspace{2\baselineskip}
}

\newenvironment{ITAabstract}{
  \begingroup
  \fontsize{9}{11}\selectfont
  \noindent\textit{Abstract: }\ignorespaces
}{
  \par
  \endgroup
  \ITArule
  \vspace{\baselineskip}
}

\newcommand{\ITAkeywords}[1]{
  \begingroup
  \fontsize{9}{11}\selectfont
  \noindent\textit{Keywords:}\par
  \noindent\hspace*{1cm}\textit{#1}\par
  \endgroup
  \vspace{\baselineskip}
}

\newcommand{\ITAacmccs}[1]{
  \begingroup
  \fontsize{9}{11}\selectfont
  \noindent\textit{ACM Computing Classification System:}\par
  \noindent\hspace*{1cm}\textit{#1}\par
  \endgroup
  \vspace{2\baselineskip}
}

\RequirePackage[numbers,sort&compress]{natbib}
